---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = "Índice de Tags";
const allPosts = Object.values(import.meta.glob<{ url: string, frontmatter: { title: string, tags: string[] } }>('../posts/*.md', { eager: true }));
const tags = [...new Set(allPosts.map((post) => post.frontmatter.tags).flat())];
---
<BaseLayout pageTitle={pageTitle}>
<!-- <ul> -->
    <div class="tags"> 
        {tags.map((tag) => (
            <p class="tag"><a href={`/tags/${tag}`}>{tag}</a></p>
        ))}
    </div>
<!-- </ul> -->
 <style>
  a {
    color: #00539F;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
  }

  .tag {
    margin: 0.25em;
    border: dotted 1px #a1a1a1;
    border-radius: .5em;
    padding: .5em 1em;
    font-size: 1.15em;
    background-color: #F8FCFD;
  }
</style>
</BaseLayout>